{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ainvil.local/schemas/harness_scenario.schema.json",
  "title": "AInvil HarnessScenario",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "title",
    "userGoal",
    "milestone",
    "interactive",
    "riskLevel",
    "expectedDocuments",
    "expectedUnityCapabilities",
    "expectedUnityArtifacts",
    "validationChecks",
    "passCriteria"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "userGoal": { "type": "string", "minLength": 1 },
    "milestone": { "type": "string", "minLength": 1 },
    "interactive": { "type": "boolean" },
    "classification": { "enum": ["Operational", "Example", "Fixture", "Deprecated"] },
    "category": { "type": "string" },
    "validationType": { "type": "string" },
    "operationalUse": { "type": "string" },
    "requirementIds": { "type": "array", "items": { "type": "string" } },
    "acceptanceIds": { "type": "array", "items": { "type": "string" } },
    "riskLevel": { "enum": ["Low", "Medium", "High"] },
    "expectedDocuments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "requirementRef", "expected"],
        "properties": {
          "type": {
            "enum": [
              "GDD",
              "Feature Spec",
              "Technical Design",
              "ProjectState",
              "TaskGraph",
              "Project Structure",
              "Scene Blueprint",
              "Component Contract",
              "Prefab Contract",
              "Input Spec",
              "UnityChangeSet",
              "Playtest Report"
            ]
          },
          "requirementRef": { "type": "string", "minLength": 1 },
          "expected": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "expectedUnityCapabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "expectedUnityArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "path", "requirementRef", "status"],
        "properties": {
          "kind": {
            "enum": [
              "Scene",
              "GameObject",
              "Component",
              "Prefab",
              "Script",
              "ScriptableObject",
              "Material",
              "UI",
              "InputAction",
              "Package",
              "ProjectSetting",
              "ValidationReport"
            ]
          },
          "path": { "type": "string", "minLength": 1 },
          "requirementRef": { "type": "string", "minLength": 1 },
          "status": {
            "enum": [
              "Implemented",
              "Prototype default",
              "Mocked",
              "Planned",
              "Needs design confirmation",
              "Needs technical confirmation"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "validationChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "target", "expected", "failureClass"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "expected": { "type": "string", "minLength": 1 },
          "failureClass": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "validationDesignPath": { "type": "string" },
    "evidenceOutputPath": { "type": "string" },
    "passCriteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
