{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ainvil.local/schemas/validation_evidence.schema.json",
  "title": "AInvil ValidationEvidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "evidenceId", "source", "scenarioId", "validationLevel", "status", "failureClass", "acceptanceIds", "requirementIds", "unityTargets", "checks", "startedAt", "finishedAt", "remainingGaps", "nextActions"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "evidenceId": { "type": "string" },
    "source": { "enum": ["LiveHarness", "UnityBridge", "Manual", "StaticValidator", "Benchmark"] },
    "scenarioId": { "type": "string" },
    "classification": { "enum": ["Operational", "Example", "Fixture", "Deprecated"] },
    "category": { "type": "string" },
    "validationType": { "type": "string" },
    "workspaceClassification": { "enum": ["ExistingWorkspace", "FreshWorkspace", "Unknown"] },
    "scratchUnityProjectPath": { "type": ["string", "null"] },
    "unityProjectPath": { "type": ["string", "null"] },
    "generatedAssets": { "type": "array", "items": { "type": "string" } },
    "dryRunReport": { "type": ["string", "null"] },
    "liveSmokeTargetProject": { "type": ["string", "null"] },
    "staleEvidenceReused": { "type": "boolean" },
    "packageInstallCheck": { "type": ["object", "null"], "additionalProperties": true },
    "validationLevel": { "enum": ["Not Checked", "Unity Inspection", "Compile Verified", "Play Mode Verified", "Runtime Tested"] },
    "status": { "enum": ["Passed", "Failed", "Blocked", "Warning", "NotRun"] },
    "result": { "enum": ["Passed", "Failed", "Blocked", "Warning", "NotRun"] },
    "validationId": { "type": ["string", "null"] },
    "validationIds": { "type": "array", "items": { "type": "string" } },
    "failureClass": { "enum": ["BridgeDisconnected", "PreconditionFailed", "CompileError", "ConsoleError", "InputNotReceived", "GameLogicFailed", "ArtifactMissing", "Timeout", "Unknown", "None"] },
    "acceptanceId": { "type": "string" },
    "acceptanceIds": { "type": "array", "items": { "type": "string" } },
    "requirementId": { "type": "string" },
    "requirementIds": { "type": "array", "items": { "type": "string" } },
    "unityTargets": { "type": "array", "items": { "type": "string" } },
    "checks": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "checkedSteps": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "bridgeHealthResult": { "type": ["object", "null"], "additionalProperties": true },
    "compileStatusResult": { "type": ["object", "null"], "additionalProperties": true },
    "compileStatus": { "type": ["object", "null"], "additionalProperties": true },
    "consoleErrorSummary": { "type": ["object", "null"], "additionalProperties": true },
    "consoleErrorCount": { "type": ["number", "null"] },
    "playModeStatus": { "type": ["object", "null"], "additionalProperties": true },
    "totalRecoveryTargetCount": { "type": ["number", "null"] },
    "initialRecoveredCount": { "type": ["number", "null"] },
    "afterFirstRecoveryCount": { "type": ["number", "null"] },
    "afterThirdRecoveryCount": { "type": ["number", "null"] },
    "isJobComplete": { "type": ["boolean", "null"] },
    "progressText": { "type": ["string", "null"] },
    "validationHookUsed": { "type": ["string", "null"] },
    "playabilityReviewStatus": { "enum": ["Passed", "Manual Review Required", "Needs Improvement", "Blocked"] },
    "buildVerificationStatus": { "enum": ["Passed", "Failed", "Blocked", "Not Run"] },
    "uxChangesApplied": { "type": "array", "items": { "type": "string" } },
    "manualAcceptanceCriteria": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "buildOutputPath": { "type": ["string", "null"] },
    "remainingPlayabilityIssues": { "type": "array", "items": { "type": "string" } },
    "failureReason": { "type": ["string", "null"] },
    "blocker": { "type": ["string", "null"] },
    "bridgeDiagnostics": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "validationResults": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "observations": { "type": ["object", "null"], "additionalProperties": true },
    "assertions": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "sourceValidationDesign": { "type": ["string", "null"] },
    "startedAt": { "type": "string" },
    "finishedAt": { "type": "string" },
    "completedAt": { "type": "string" },
    "timestamp": { "type": "string" },
    "remainingGaps": { "type": "array", "items": { "type": "string" } },
    "nextActions": { "type": "array", "items": { "type": "string" } }
  }
}
