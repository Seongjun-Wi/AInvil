{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ainvil.local/schemas/onboarding_doctor_report.schema.json",
  "title": "AInvil OnboardingDoctorReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "reportId", "generatedAt", "product", "workspaceManifest", "unityRpcUrl", "healthUrl", "releaseReadiness", "summary", "checks", "nextActions"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "reportId": { "type": "string" },
    "generatedAt": { "type": "string" },
    "product": { "const": "AInvil" },
    "workspaceManifest": { "type": "string" },
    "unityRpcUrl": { "type": "string" },
    "healthUrl": { "type": "string" },
    "releaseReadiness": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "warning", "failed", "blocked"],
      "additionalProperties": false,
      "properties": {
        "total": { "type": "integer" },
        "passed": { "type": "integer" },
        "warning": { "type": "integer" },
        "failed": { "type": "integer" },
        "blocked": { "type": "integer" }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "importance", "status", "message"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "category": { "type": "string" },
          "importance": { "type": "string" },
          "status": { "type": "string" },
          "message": { "type": "string" },
          "nextAction": { "type": ["string", "null"] }
        }
      }
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["checkId", "status", "summary"],
        "additionalProperties": false,
        "properties": {
          "checkId": { "type": "string" },
          "status": { "type": "string" },
          "summary": { "type": "string" }
        }
      }
    }
  }
}
