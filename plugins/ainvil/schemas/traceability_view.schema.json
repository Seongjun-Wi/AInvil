{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ainvil.local/schemas/traceability_view.schema.json",
  "title": "AInvil TraceabilityView",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "viewId", "generatedAt", "sourceGraphId", "rows", "proposedLinks", "summary"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "viewId": { "type": "string" },
    "generatedAt": { "type": "string" },
    "sourceGraphId": { "type": "string" },
    "rows": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "proposedLinks": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "summary": { "type": "object", "additionalProperties": true }
  }
}
