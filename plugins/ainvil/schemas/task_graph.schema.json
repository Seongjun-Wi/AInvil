{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ainvil.local/schemas/task_graph.schema.json",
  "title": "AInvil TaskGraph",
  "type": "object",
  "required": ["schemaVersion", "tasks"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "agent", "title", "status"],
        "properties": {
          "id": { "type": "string" },
          "agent": { "enum": ["AInvil", "GDD Agent", "Unity Agent", "Input Agent"] },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "dependsOn": { "type": "array", "items": { "type": "string" } },
          "requiredInputs": { "type": "array", "items": { "type": "string" } },
          "producedOutputs": { "type": "array", "items": { "type": "string" } },
          "inputs": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "blockingConditions": { "type": "array", "items": { "type": "string" } },
          "currentOwner": { "enum": ["AInvil", "GDD Agent", "Unity Agent", "Input Agent"] },
          "waitingAgent": { "enum": ["AInvil", "GDD Agent", "Unity Agent", "Input Agent", "None"] },
          "completedAgent": { "enum": ["AInvil", "GDD Agent", "Unity Agent", "Input Agent", "None"] },
          "nextAgent": { "enum": ["AInvil", "GDD Agent", "Unity Agent", "Input Agent", "None"] },
          "status": { "enum": ["Planned", "In Progress", "Blocked", "Implemented", "Validated", "Deferred", "Cut", "In progress", "Done"] },
          "blocker": { "type": ["string", "null"] },
          "retryCount": { "type": "integer", "minimum": 0, "default": 0 },
          "validation": { "enum": ["Not tested", "Pass", "Fail", "Blocked"] },
          "validationLevel": {
            "enum": [
              "Not Checked",
              "Document Review",
              "Static Analysis",
              "Unity Inspection",
              "Compile Verified",
              "Play Mode Verified",
              "Runtime Tested",
              "User Confirmed"
            ]
          },
          "riskReport": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["risk", "impact", "likelihood", "possibleMitigation"],
              "properties": {
                "risk": { "type": "string" },
                "impact": { "type": "string" },
                "likelihood": { "type": "string" },
                "possibleMitigation": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
